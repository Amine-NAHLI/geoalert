<!-- views/partials/loader.ejs -->
<!-- Loader global centré pour GeoAlert -->
<div id="global-loader" class="loader-overlay" style="display: none;">
  <div class="loader-container">
    <!-- Animation radar/pulse -->
    <div class="radar-spinner">
      <div class="radar-center"></div>
      <div class="radar-pulse"></div>
      <div class="radar-pulse delay-1"></div>
      <div class="radar-pulse delay-2"></div>
    </div>

    <!-- Spinner classique -->
    <div class="loader-spinner">
      <div class="spinner-inner"></div>
    </div>

    <!-- Texte de chargement -->
    <div class="loader-text">Chargement des données trafic...</div>
  </div>
</div>