<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="GeoAlert - Application de trafic en temps réel ">
  <title>GeoAlert - Trafic Maroc</title>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Three.js -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      height: 100%;
      font-family: 'Rajdhani', sans-serif;
      overflow-x: hidden;
      cursor: none;
    }

    body {
      background: #050510;
      color: white;
      position: relative;
    }

    /* Custom Cursor */
    .cursor {
      position: fixed;
      width: 20px;
      height: 20px;
      border: 2px solid #c0392b;
      border-radius: 50%;
      pointer-events: none;
      z-index: 9999;
      transition: transform 0.1s ease;
    }

    .cursor-trail {
      position: fixed;
      width: 4px;
      height: 4px;
      background: #c0392b;
      border-radius: 50%;
      pointer-events: none;
      z-index: 9998;
      opacity: 0.7;
    }

    /* Canvas Background */
    #bg-canvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: -1;
    }

    /* Three.js Container */
    #three-container {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: -1;
      opacity: 0.8;
    }

    /* Navbar */
    .navbar {
      position: fixed;
      top: 0;
      width: 100%;
      padding: 20px 40px;
      z-index: 100;
      backdrop-filter: blur(10px);
      background: rgba(5, 5, 16, 0.8);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .navbar-content {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .logo {
      font-family: 'Orbitron', monospace;
      font-size: 24px;
      font-weight: 700;
      color: #c0392b;
      text-shadow: 0 0 20px rgba(192, 57, 43, 0.5);
    }

    .nav-links {
      display: flex;
      gap: 30px;
    }

    .nav-link {
      color: white;
      text-decoration: none;
      font-weight: 500;
      transition: color 0.3s;
    }

    .nav-link:hover {
      color: #c0392b;
    }

    /* Hero Section */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 120px 20px 80px;
      text-align: center;
      position: relative;
    }

    .hero-title {
      font-family: 'Orbitron', monospace;
      font-size: clamp(48px, 8vw, 120px);
      font-weight: 900;
      color: #c0392b;
      text-shadow:
        0 0 30px rgba(192, 57, 43, 0.8),
        0 0 60px rgba(192, 57, 43, 0.6),
        0 0 90px rgba(192, 57, 43, 0.4),
        0 10px 20px rgba(0, 0, 0, 0.5);
      margin-bottom: 20px;
      animation: titleGlow 2s ease-in-out infinite alternate;
    }

    @keyframes titleGlow {
      from { text-shadow: 0 0 30px rgba(192, 57, 43, 0.8), 0 0 60px rgba(192, 57, 43, 0.6), 0 0 90px rgba(192, 57, 43, 0.4), 0 10px 20px rgba(0, 0, 0, 0.5); }
      to { text-shadow: 0 0 40px rgba(192, 57, 43, 1), 0 0 80px rgba(192, 57, 43, 0.8), 0 0 120px rgba(192, 57, 43, 0.6), 0 15px 30px rgba(0, 0, 0, 0.7); }
    }

    .hero-subtitle {
      font-size: clamp(16px, 2vw, 24px);
      font-weight: 300;
      color: white;
      margin-bottom: 60px;
      opacity: 0;
      animation: fadeInLetters 3s ease-out 1s forwards;
      line-height: 1.6;
    }

    @keyframes fadeInLetters {
      0% { opacity: 0; transform: translateY(20px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    /* Features Section */
    .features {
      padding: 100px 20px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .features-title {
      text-align: center;
      font-size: clamp(24px, 4vw, 36px);
      font-weight: 600;
      margin-bottom: 60px;
      color: white;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 40px;
      perspective: 1000px;
    }

    .feature-card {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 20px;
      padding: 40px 30px;
      text-align: center;
      transition: transform 0.3s ease;
      transform-style: preserve-3d;
      animation: float 6s ease-in-out infinite;
      position: relative;
      overflow: hidden;
    }

    .feature-card:nth-child(2) { animation-delay: -2s; }
    .feature-card:nth-child(3) { animation-delay: -4s; }

    @keyframes float {
      0%, 100% { transform: translateY(0px) rotateX(0deg) rotateY(0deg); }
      50% { transform: translateY(-10px) rotateX(2deg) rotateY(2deg); }
    }

    .feature-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
      transition: left 0.5s;
    }

    .feature-card:hover::before {
      left: 100%;
    }

    .feature-icon {
      width: 80px;
      height: 80px;
      margin: 0 auto 20px;
      fill: #c0392b;
      filter: drop-shadow(0 0 20px rgba(192, 57, 43, 0.5));
    }

    .feature-title {
      font-size: 24px;
      font-weight: 600;
      margin-bottom: 15px;
      color: white;
    }

    .feature-description {
      color: rgba(255, 255, 255, 0.8);
      line-height: 1.6;
    }

    /* Buttons */
    .cta-buttons {
      display: flex;
      gap: 20px;
      justify-content: center;
      margin-top: 60px;
      flex-wrap: wrap;
    }

    .btn {
      padding: 16px 32px;
      border-radius: 50px;
      font-size: 18px;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
      min-width: 160px;
      text-align: center;
    }

    .btn-primary {
      background: #c0392b;
      color: white;
      box-shadow: 0 8px 32px rgba(192, 57, 43, 0.3);
    }

    .btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 40px rgba(192, 57, 43, 0.5);
    }

    .btn-secondary {
      background: transparent;
      color: white;
      border: 2px solid white;
    }

    .btn-secondary:hover {
      background: white;
      color: #050510;
      transform: translateY(-3px);
    }

    .btn::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
      transition: left 0.5s;
    }

    .btn:hover::before {
      left: 100%;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .navbar {
        padding: 15px 20px;
      }

      .nav-links {
        gap: 20px;
      }

      .hero {
        padding: 100px 20px 60px;
      }

      .features {
        padding: 60px 20px;
      }

      .features-grid {
        grid-template-columns: 1fr;
        gap: 30px;
      }

      .cta-buttons {
        flex-direction: column;
        align-items: center;
      }

      .btn {
        width: 100%;
        max-width: 300px;
      }
    }
  </style>
</head>
<body>
  <!-- Custom Cursor -->
  <div class="cursor"></div>
  <div class="cursor-trail"></div>

  <!-- Background Canvas -->
  <canvas id="bg-canvas"></canvas>

  <!-- Three.js Container -->
  <div id="three-container"></div>

  <!-- Navbar -->
  <nav class="navbar">
    <div class="navbar-content">
      <div class="logo">GeoAlert</div>
      <div class="nav-links">
        <a href="#features" class="nav-link">Fonctionnalités</a>
        <a href="#about" class="nav-link">À propos</a>
        <a href="/auth/login" class="nav-link">Connexion</a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="hero">
    <h1 class="hero-title">GeoAlert</h1>
    <p class="hero-subtitle">Application de trafic en temps réel au Maroc</p>

    <div class="cta-buttons">
      <a href="/auth/login" class="btn btn-primary">Se connecter</a>
      <a href="/auth/register" class="btn btn-secondary">S'inscrire</a>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="features" style="padding-top: 120px; padding-bottom: 80px;">
    <h2 class="features-title">À propos de GeoAlert</h2>
    <div class="features-grid">
      <div class="feature-card" style="grid-column: 1 / -1; background: rgba(255, 255, 255, 0.08); border-color: rgba(192, 57, 43, 0.2);">
        <h3 class="feature-title" style="color: #fff;">Une sécurité routière collaborative</h3>
        <p class="feature-description" style="color: rgba(255,255,255,0.85);">
          GeoAlert est une plateforme participative dédiée au trafic au Maroc. Les conducteurs signalent accidents, bouchons, radars, travaux et dangers en temps réel. Les alertes sont immédiatement visibles sur la carte et diffusées à tous les utilisateurs connectés.
        </p>
      </div>
      <div class="feature-card" style="background: rgba(255, 255, 255, 0.07); border-color: rgba(192, 57, 43, 0.15);">
        <h3 class="feature-title" style="color: #fff;">Technologie en temps réel</h3>
        <p class="feature-description" style="color: rgba(255,255,255,0.85);">
          GeoAlert utilise WebSocket (Socket.IO) pour recevoir et afficher instantanément chaque nouveau signalement, sans rechargement de page. La carte Leaflet se synchronise automatiquement pour rester à jour.
        </p>
      </div>
      <div class="feature-card" style="background: rgba(255, 255, 255, 0.07); border-color: rgba(192, 57, 43, 0.15);">
        <h3 class="feature-title" style="color: #fff;">Simple et accessible</h3>
        <p class="feature-description" style="color: rgba(255,255,255,0.85);">
          Inscription rapide, connexion sécurisée et formulaire d’ajout d’incidents avec géolocalisation automatique. Conçu pour être intuitif sur mobile et desktop.
        </p>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="features">
    <h2 class="features-title">Fonctionnalités Principales</h2>
    <div class="features-grid">
      <div class="feature-card">
        <svg class="feature-icon" viewBox="0 0 24 24">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        <h3 class="feature-title">Incidents en Temps Réel</h3>
        <p class="feature-description">Signalez et consultez les incidents routiers en temps réel sur tout le territoire marocain.</p>
      </div>

      <div class="feature-card">
        <svg class="feature-icon" viewBox="0 0 24 24">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        <h3 class="feature-title">Géolocalisation Précise</h3>
        <p class="feature-description">Localisation GPS précise pour une couverture complète des routes marocaines.</p>
      </div>

      <div class="feature-card">
        <svg class="feature-icon" viewBox="0 0 24 24">
          <path d="M16 4c0-1.11.89-2 2-2s2 .89 2 2-.89 2-2 2-2-.89-2-2zm4 18v-6h2.5l-2.54-7.63C19.68 7.55 18.92 7 18.06 7h-.12c-.86 0-1.63.55-1.9 1.37l-.86 2.58c-.28.84-.98 1.43-1.82 1.43-.18 0-.36-.02-.53-.05L9.83 9.08c-.57-.16-1.15-.08-1.65.22L6.5 11H4c-1.1 0-2 .9-2 2v6c0 1.1.9 2 2 2h1v-2H4v-6h1.5l.15-.15 2.35-2.35c.2-.2.5-.2.7 0l1.65 1.65c.2.2.2.5 0 .7L9.05 13H10c.55 0 1 .45 1 1s-.45 1-1 1H8v2h2c1.66 0 3-1.34 3-3s-1.34-3-3-3H7.5l-.15.15-2.35 2.35c-.2.2-.5.2-.7 0L2.05 13H2v6h1v2h16v-2h-3z"/>
        </svg>
        <h3 class="feature-title">Communauté Marocaine</h3>
        <p class="feature-description">Rejoignez une communauté active de conducteurs marocains partageant des informations en temps réel.</p>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>

  <script src="/loader.js"></script>
  <script>
    // Custom Cursor
    const cursor = document.querySelector('.cursor');
    const cursorTrail = document.querySelector('.cursor-trail');
    let mouseX = 0, mouseY = 0;
    let trailX = 0, trailY = 0;

    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      cursor.style.left = mouseX - 10 + 'px';
      cursor.style.top = mouseY - 10 + 'px';
    });

    function updateTrail() {
      trailX += (mouseX - trailX) * 0.1;
      trailY += (mouseY - trailY) * 0.1;
      cursorTrail.style.left = trailX - 2 + 'px';
      cursorTrail.style.top = trailY - 2 + 'px';
      requestAnimationFrame(updateTrail);
    }
    updateTrail();

    // Background Stars
    const canvas = document.getElementById('bg-canvas');
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    const stars = [];
    for (let i = 0; i < 200; i++) {
      stars.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        radius: Math.random() * 2,
        opacity: Math.random(),
        speed: Math.random() * 0.5
      });
    }

    function animateStars() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      stars.forEach(star => {
        star.opacity += star.speed * 0.01;
        if (star.opacity > 1) star.opacity = 0;
        ctx.beginPath();
        ctx.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255, 255, 255, ${star.opacity})`;
        ctx.fill();
      });
      requestAnimationFrame(animateStars);
    }
    animateStars();

    // Three.js Globe
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    document.getElementById('three-container').appendChild(renderer.domElement);

    // Earth
    const earthGeometry = new THREE.SphereGeometry(5, 64, 64);
    const earthMaterial = new THREE.MeshPhongMaterial({
      map: new THREE.TextureLoader().load('https://threejs.org/examples/textures/planets/earth_atmos_2048.jpg'),
      transparent: true,
      opacity: 0.8
    });
    const earth = new THREE.Mesh(earthGeometry, earthMaterial);
    scene.add(earth);

    // Moroccan Cities
    const cities = [
      { name: 'Casablanca', lat: 33.5731, lng: -7.5898 },
      { name: 'Rabat', lat: 34.0209, lng: -6.8416 },
      { name: 'Marrakech', lat: 31.6295, lng: -8.0083 },
      { name: 'Fès', lat: 34.0331, lng: -5.0003 },
      { name: 'Tanger', lat: 35.7595, lng: -5.8340 }
    ];

    const cityPoints = [];
    cities.forEach(city => {
      const phi = (90 - city.lat) * (Math.PI / 180);
      const theta = (city.lng + 180) * (Math.PI / 180);
      const x = -(5.2 * Math.sin(phi) * Math.cos(theta));
      const z = 5.2 * Math.sin(phi) * Math.sin(theta);
      const y = 5.2 * Math.cos(phi);

      const pointGeometry = new THREE.SphereGeometry(0.05, 8, 8);
      const pointMaterial = new THREE.MeshBasicMaterial({ color: 0xc0392b });
      const point = new THREE.Mesh(pointGeometry, pointMaterial);
      point.position.set(x, y, z);
      scene.add(point);
      cityPoints.push(point);
    });

    // Connection Lines
    const lineMaterial = new THREE.LineBasicMaterial({ color: 0xc0392b, transparent: true, opacity: 0.6 });
    for (let i = 0; i < cityPoints.length; i++) {
      for (let j = i + 1; j < cityPoints.length; j++) {
        const geometry = new THREE.BufferGeometry().setFromPoints([
          cityPoints[i].position,
          cityPoints[j].position
        ]);
        const line = new THREE.Line(geometry, lineMaterial);
        scene.add(line);
      }
    }

    // Particles
    const particleGeometry = new THREE.BufferGeometry();
    const particleCount = 1000;
    const positions = new Float32Array(particleCount * 3);
    for (let i = 0; i < particleCount * 3; i++) {
      positions[i] = (Math.random() - 0.5) * 50;
    }
    particleGeometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    const particleMaterial = new THREE.PointsMaterial({ color: 0xffffff, size: 0.02 });
    const particles = new THREE.Points(particleGeometry, particleMaterial);
    scene.add(particles);

    // Lighting
    const ambientLight = new THREE.AmbientLight(0x404040, 0.6);
    scene.add(ambientLight);
    const directionalLight = new THREE.DirectionalLight(0xffffff, 0.8);
    directionalLight.position.set(1, 1, 1);
    scene.add(directionalLight);

    camera.position.z = 15;

    // Animation
    function animate() {
      requestAnimationFrame(animate);
      earth.rotation.y += 0.005;
      particles.rotation.y += 0.001;
      renderer.render(scene, camera);
    }
    animate();

    // 3D Card Tilt Effect
    document.querySelectorAll('.feature-card').forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        const rotateX = (y - centerY) / 10;
        const rotateY = (centerX - x) / 10;
        card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-10px)`;
      });

      card.addEventListener('mouseleave', () => {
        card.style.transform = '';
      });
    });

    // Scroll Reveal
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
        }
      });
    }, observerOptions);

    document.querySelectorAll('.feature-card').forEach(card => {
      card.style.opacity = '0';
      card.style.transform = 'translateY(50px)';
      card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      observer.observe(card);
    });

    // Resize Handler
    window.addEventListener('resize', () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });
  </script>
</body>
</html>