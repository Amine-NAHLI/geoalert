<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#1a2a6c">
  <meta name="description" content="GeoAlert - Votre solution de trafic en temps réel. Signalez les incidents routiers et restez informé en direct.">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>GeoAlert - Alertes Trafic en Temps Réel</title>
  <link rel="stylesheet" href="/style.css">
  
  <style>
    /* ============================================
       LANDING PAGE INDEX - RESPONSIVE MOBILE-FIRST
       ============================================ */
    
    * {
      box-sizing: border-box;
    }
    
    html,
    body {
      margin: 0;
      padding: 0;
      height: 100%;
      width: 100%;
    }
    
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      background: white;
    }
    
    /* ============================================
       HERO SECTION
       ============================================ */
    
    .hero {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #1a2a6c 0%, #2a3f8f 50%, #b21f1f 100%);
      padding: 20px;
      position: relative;
      overflow: hidden;
      text-align: center;
      min-height: 100vh;
    }
    
    /* Effet de background animé */
    .hero::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: 
        radial-gradient(circle at 20% 50%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, rgba(255, 255, 255, 0.05) 0%, transparent 50%);
      pointer-events: none;
    }
    
    .hero-content {
      position: relative;
      z-index: 10;
      display: flex;
      flex-direction: column;
      gap: 30px;
      max-width: 600px;
      width: 100%;
    }
    
    /* LOGO/BRANDING */
    .hero-logo {
      font-size: 48px;
      line-height: 1;
      margin: 0;
      animation: slide-down 0.6s ease-out;
    }
    
    @keyframes slide-down {
      from {
        opacity: 0;
        transform: translateY(-30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    
    /* TITRE PRINCIPAL */
    .hero-title {
      color: white;
      font-size: 32px;
      font-weight: 800;
      line-height: 1.3;
      margin: 0;
      letter-spacing: -0.5px;
      animation: slide-down 0.7s ease-out 0.1s both;
    }
    
    /* SOUS-TITRE */
    .hero-subtitle {
      color: rgba(255, 255, 255, 0.95);
      font-size: 16px;
      font-weight: 300;
      line-height: 1.6;
      margin: 0;
      animation: slide-down 0.8s ease-out 0.2s both;
    }
    
    /* CARACTÉRISTIQUES PRINCIPALES */
    .hero-features {
      display: flex;
      flex-direction: column;
      gap: 12px;
      color: rgba(255, 255, 255, 0.9);
      font-size: 14px;
      animation: slide-down 0.9s ease-out 0.3s both;
    }
    
    .feature-item {
      display: flex;
      align-items: center;
      gap: 10px;
      justify-content: center;
    }
    
    /* BOUTONS */
    .hero-buttons {
      display: flex;
      flex-direction: column;
      gap: 12px;
      animation: slide-down 1s ease-out 0.4s both;
    }
    
    .btn-hero {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 52px;
      padding: 14px 28px;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 700;
      text-decoration: none;
      cursor: pointer;
      border: 2px solid transparent;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      width: 100%;
      text-align: center;
      letter-spacing: 0.3px;
    }
    
    .btn-primary {
      background: linear-gradient(90deg, #1a2a6c, #b21f1f);
      color: white;
      box-shadow: 0 8px 24px rgba(26, 42, 108, 0.35);
    }
    
    .btn-primary:hover,
    .btn-primary:focus {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(26, 42, 108, 0.45);
    }
    
    .btn-primary:active {
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(26, 42, 108, 0.3);
    }
    
    .btn-secondary {
      background: rgba(255, 255, 255, 0.95);
      color: #1a2a6c;
      font-weight: 700;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
      border: 2px solid white;
    }
    
    .btn-secondary:hover,
    .btn-secondary:focus {
      background: white;
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.15);
    }
    
    .btn-secondary:active {
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.1);
    }
    
    /* FOOTER */
    footer {
      background-color: #0f1931;
      color: rgba(255, 255, 255, 0.8);
      padding: 20px;
      text-align: center;
      font-size: 13px;
      flex-shrink: 0;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    footer strong {
      color: white;
    }
    
    footer a {
      color: #b21f1f;
      text-decoration: none;
      font-weight: 600;
      transition: color 0.3s;
    }
    
    footer a:hover {
      color: #c0392b;
      text-decoration: underline;
    }
    
    /* ============================================
       RESPONSIVE - MOBILE < 480px
       ============================================ */
    
    @media (max-width: 479px) {
      .hero {
        padding: 16px;
        min-height: 100vh;
      }
      
      .hero-logo {
        font-size: 40px;
      }
      
      .hero-title {
        font-size: 28px;
      }
      
      .hero-subtitle {
        font-size: 15px;
      }
      
      .hero-features {
        font-size: 13px;
      }
      
      .hero-content {
        gap: 24px;
      }
      
      footer {
        padding: 16px 12px;
        font-size: 12px;
      }
    }
    
    /* ============================================
       RESPONSIVE - TABLET 480px - 768px
       ============================================ */
    
    @media (min-width: 480px) and (max-width: 767px) {
      .hero {
        padding: 24px;
      }
      
      .hero-logo {
        font-size: 48px;
      }
      
      .hero-title {
        font-size: 32px;
      }
      
      .hero-subtitle {
        font-size: 16px;
      }
      
      .hero-content {
        gap: 28px;
      }
      
      .btn-hero {
        min-height: 50px;
        font-size: 15px;
      }
    }
    
    /* ============================================
       RESPONSIVE - DESKTOP >= 768px
       ============================================ */
    
    @media (min-width: 768px) {
      .hero {
        padding: 40px 60px;
      }
      
      .hero-logo {
        font-size: 56px;
        margin-bottom: 12px;
      }
      
      .hero-title {
        font-size: 44px;
        letter-spacing: -0.8px;
      }
      
      .hero-subtitle {
        font-size: 18px;
        opacity: 0.98;
      }
      
      .hero-features {
        font-size: 15px;
        gap: 14px;
      }
      
      .hero-content {
        gap: 36px;
        max-width: 700px;
      }
      
      /* Boutons côte à côte */
      .hero-buttons {
        flex-direction: row;
        gap: 16px;
        justify-content: center;
      }
      
      .btn-hero {
        flex: 1;
        max-width: 240px;
        min-height: 52px;
        font-size: 16px;
      }
      
      footer {
        padding: 24px;
        font-size: 14px;
      }
    }
    
    /* ============================================
       RESPONSIVE - LARGE DESKTOP >= 1024px
       ============================================ */
    
    @media (min-width: 1024px) {
      .hero-title {
        font-size: 48px;
      }
      
      .hero-subtitle {
        font-size: 20px;
      }
      
      .hero-content {
        gap: 40px;
      }
      
      .hero-features {
        font-size: 16px;
        gap: 16px;
      }
      
      .btn-hero {
        max-width: 280px;
        font-size: 17px;
        min-height: 56px;
      }
    }
  </style>
</head>
<body>
  <!-- HERO SECTION -->
  <section class="hero">
    <div class="hero-content">
      <!-- LOGO/BRANDING -->
      <div class="hero-logo">🗺️</div>
      
      <!-- TITRE PRINCIPAL -->
      <h1 class="hero-title">GeoAlert</h1>
      
      <!-- SOUS-TITRE -->
      <p class="hero-subtitle">Découvrez les incidents routiers en temps réel et restez informé de votre trajet</p>
      
      <!-- CARACTÉRISTIQUES PRINCIPALES -->
      <div class="hero-features">
        <div class="feature-item">
          <span>⚡</span>
          <span>Alertes instantanées</span>
        </div>
        <div class="feature-item">
          <span>📍</span>
          <span>Géolocalisation précise</span>
        </div>
        <div class="feature-item">
          <span>👥</span>
          <span>Communauté Marocaine</span>
        </div>
      </div>
      
      <!-- BOUTONS D'ACTION -->
      <div class="hero-buttons">
        <a href="/auth/login" class="btn-hero btn-primary" aria-label="Se connecter à GeoAlert">
          🔑 Se connecter
        </a>
        <a href="/auth/register" class="btn-hero btn-secondary" aria-label="Créer un compte GeoAlert">
          ✍️ S'inscrire
        </a>
      </div>
    </div>
  </section>
  
  <!-- FOOTER -->
  <footer>
    <p>
      🇲🇦 <strong>GeoAlert</strong> - Créé avec ❤️ par 
      <strong>Kenza Boutarfass</strong>, 
      <strong>Amine Nahli</strong> et 
      <strong>Lina Oujdi</strong>
    </p>
    <p style="margin: 8px 0 0 0; font-size: 0.9em;">
      Un projet Marocain pour signaler les incidents routiers en temps réel
    </p>
  </footer>
</body>
</html>
