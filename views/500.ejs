<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Erreur Serveur - GeoAlert</title>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      height: 100%;
      font-family: 'Rajdhani', sans-serif;
      overflow-x: hidden;
    }

    body {
      background: #050510;
      color: white;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      position: relative;
    }

    /* Canvas Background */
    #bg-canvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: -1;
    }

    /* Logo */
    .logo {
      font-family: 'Orbitron', monospace;
      font-size: 32px;
      font-weight: 700;
      color: #c0392b;
      text-shadow: 0 0 20px rgba(192, 57, 43, 0.5);
      margin-bottom: 40px;
      text-align: center;
    }

    /* Error Container */
    .error-container {
      text-align: center;
      max-width: 600px;
      padding: 0 20px;
    }

    /* Error Code */
    .error-code {
      font-family: 'Orbitron', monospace;
      font-size: clamp(120px, 20vw, 200px);
      font-weight: 900;
      color: #c0392b;
      text-shadow:
        0 0 30px rgba(192, 57, 43, 0.8),
        0 0 60px rgba(192, 57, 43, 0.6),
        0 0 90px rgba(192, 57, 43, 0.4),
        0 10px 20px rgba(0, 0, 0, 0.5);
      margin-bottom: 20px;
      line-height: 1;
      letter-spacing: -5px;
      animation: glow 2s ease-in-out infinite alternate;
    }

    @keyframes glow {
      from {
        text-shadow:
          0 0 30px rgba(192, 57, 43, 0.8),
          0 0 60px rgba(192, 57, 43, 0.6),
          0 0 90px rgba(192, 57, 43, 0.4),
          0 10px 20px rgba(0, 0, 0, 0.5);
      }
      to {
        text-shadow:
          0 0 40px rgba(192, 57, 43, 1),
          0 0 80px rgba(192, 57, 43, 0.8),
          0 0 120px rgba(192, 57, 43, 0.6),
          0 15px 30px rgba(0, 0, 0, 0.7);
      }
    }

    /* Error Title */
    .error-title {
      font-family: 'Orbitron', monospace;
      font-size: clamp(24px, 4vw, 36px);
      font-weight: 700;
      color: white;
      margin-bottom: 15px;
      text-shadow: 0 0 10px rgba(255, 255, 255, 0.3);
    }

    /* Error Message */
    .error-message {
      font-size: clamp(16px, 2vw, 20px);
      color: rgba(255, 255, 255, 0.8);
      margin-bottom: 40px;
      line-height: 1.6;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
    }

    /* Home Button */
    .home-btn {
      display: inline-block;
      padding: 16px 32px;
      background: #c0392b;
      color: white;
      text-decoration: none;
      border-radius: 50px;
      font-size: 18px;
      font-weight: 600;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
      box-shadow: 0 8px 32px rgba(192, 57, 43, 0.3);
    }

    .home-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 40px rgba(192, 57, 43, 0.5);
    }

    .home-btn::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
      transition: left 0.5s;
    }

    .home-btn:hover::before {
      left: 100%;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .logo {
        font-size: 24px;
        margin-bottom: 30px;
      }

      .error-container {
        padding: 0 15px;
      }

      .error-code {
        font-size: clamp(80px, 25vw, 120px);
        letter-spacing: -3px;
      }

      .error-title {
        font-size: clamp(20px, 5vw, 28px);
      }

      .error-message {
        font-size: clamp(14px, 3vw, 16px);
      }

      .home-btn {
        padding: 14px 28px;
        font-size: 16px;
      }
    }
  </style>
  <script src="/loader.js"></script>
</head>
<body>
  <!-- Background Canvas -->
  <canvas id="bg-canvas"></canvas>

  <!-- Logo -->
  <div class="logo">GeoAlert</div>

  <!-- Error Container -->
  <div class="error-container">
    <div class="error-code">500</div>
    <h1 class="error-title">Erreur Serveur</h1>
    <p class="error-message">
      Désolé, une erreur inattendue s'est produite sur le serveur. Nos équipes ont été notifiées.
    </p>
    <a href="/" class="home-btn">Retour à l'accueil</a>
  </div>

  <%- include('partials/footer') %>

  <script>
    // Background Stars
    const canvas = document.getElementById('bg-canvas');
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    const stars = [];
    for (let i = 0; i < 200; i++) {
      stars.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        radius: Math.random() * 2,
        opacity: Math.random(),
        speed: Math.random() * 0.5
      });
    }

    function animateStars() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      stars.forEach(star => {
        star.opacity += star.speed * 0.01;
        if (star.opacity > 1) star.opacity = 0;
        ctx.beginPath();
        ctx.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255, 255, 255, ${star.opacity})`;
        ctx.fill();
      });
      requestAnimationFrame(animateStars);
    }
    animateStars();

    // Resize Handler
    window.addEventListener('resize', () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    });
  </script>
</body>
</html>
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
      animation: bounce-in 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    
    @keyframes bounce-in {
      0% {
        opacity: 0;
        transform: scale(0.85);
      }
      100% {
        opacity: 1;
        transform: scale(1);
      }
    }
    
    /* EMOJI ERREUR */
    .error-emoji {
      font-size: 64px;
      display: block;
      margin: 0;
      animation: pulse 1.5s ease-in-out infinite;
    }
    
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.7; transform: scale(1.05); }
    }
    
    /* CODE D'ERREUR */
    .error-code {
      font-size: 72px;
      font-weight: 900;
      color: #b21f1f;
      margin: 0;
      line-height: 1;
      letter-spacing: -2px;
    }
    
    /* TITRE ERREUR */
    .error-title {
      font-size: 28px;
      font-weight: 700;
      color: #1a2a6c;
      margin: 0;
      line-height: 1.3;
    }
    
    /* MESSAGE ERREUR */
    .error-message {
      font-size: 15px;
      color: #666;
      margin: 0;
      line-height: 1.6;
      background-color: #fff3cd;
      padding: 12px 15px;
      border-radius: 6px;
      border-left: 4px solid #b21f1f;
    }
    
    .error-message strong {
      color: #b21f1f;
    }
    
    .default-message {
      background-color: #f8f9fa;
      border-left-color: #1a2a6c;
    }
    
    /* BOUTON RETOUR */
    .home-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 14px 32px;
      background: linear-gradient(90deg, #1a2a6c, #b21f1f);
      color: white;
      text-decoration: none;
      border-radius: 6px;
      font-weight: 700;
      font-size: 15px;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 8px 24px rgba(26, 42, 108, 0.35);
      border: none;
      margin-top: 10px;
    }
    
    .home-link:hover,
    .home-link:focus {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(26, 42, 108, 0.45);
    }
    
    .home-link:active {
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(26, 42, 108, 0.3);
    }
    
    /* STATUS CODE 500 - SPECIAL STYLING */
    .error-details {
      font-size: 13px;
      color: #999;
      margin: 8px 0 0 0;
      font-style: italic;
    }
    
    /* RESPONSIVE MOBILE < 480px */
    @media (max-width: 479px) {
      body {
        padding: 16px;
      }
      
      .error-container {
        padding: 32px 16px;
        gap: 16px;
        border-radius: 10px;
      }
      
      .error-emoji {
        font-size: 52px;
      }
      
      .error-code {
        font-size: 56px;
      }
      
      .error-title {
        font-size: 24px;
      }
      
      .error-message {
        font-size: 13px;
        padding: 10px 12px;
      }
      
      .home-link {
        min-height: 44px;
        padding: 12px 24px;
        font-size: 14px;
        width: 100%;
      }
    }
    
    /* RESPONSIVE TABLET 480px - 768px */
    @media (min-width: 480px) and (max-width: 767px) {
      .error-container {
        padding: 40px 24px;
      }
      
      .error-emoji {
        font-size: 60px;
      }
      
      .error-code {
        font-size: 64px;
      }
      
      .error-title {
        font-size: 26px;
      }
    }
    
    /* RESPONSIVE DESKTOP >= 768px */
    @media (min-width: 768px) {
      body {
        padding: 40px 20px;
      }
      
      .error-container {
        padding: 60px 40px;
        gap: 24px;
        border-radius: 16px;
        box-shadow: 0 28px 80px rgba(0, 0, 0, 0.25);
      }
      
      .error-emoji {
        font-size: 80px;
      }
      
      .error-code {
        font-size: 88px;
        margin: 10px 0;
      }
      
      .error-title {
        font-size: 36px;
      }
      
      .error-message {
        font-size: 15px;
        max-width: 400px;
        padding: 14px 18px;
      }
      
      .home-link {
        min-height: 52px;
        padding: 16px 40px;
        font-size: 16px;
        margin-top: 12px;
      }
    }
  </style>
</head>
<body>
  <div class="error-container">
    <span class="error-emoji">🔧⚠️</span>
    <h1 class="error-code">500</h1>
    <h2 class="error-title">Erreur Serveur</h2>
    
    <% if (typeof error !== 'undefined' && error) { %>
      <p class="error-message">
        <strong>Détails :</strong><br>
        <%= error %>
      </p>
    <% } else { %>
      <p class="error-message default-message">
        Une erreur interne du serveur s'est produite. Nos équipes en ont été notifiées et travaillent à la résolution du problème.
      </p>
    <% } %>
    
    <p class="error-details">Code d'erreur : 500 - Erreur Interne du Serveur</p>
    <a href="/" class="home-link">🏠 Retour à l'accueil</a>
  </div>
</body>
</html>