<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#1a2a6c">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>GeoAlert - Carte d'incidents en temps réel</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      height: 100%;
      font-family: 'Rajdhani', sans-serif;
      overflow-x: hidden;
    }

    body {
      background: #050510;
      color: white;
    }

    /* Header */
    .header {
      background: #050510;
      padding: 15px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      position: relative;
      z-index: 1000;
    }

    .logo {
      font-family: 'Orbitron', monospace;
      font-size: 24px;
      font-weight: 700;
      color: #c0392b;
      text-shadow: 0 0 20px rgba(192, 57, 43, 0.5);
    }

    .user-info {
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .user-name {
      color: white;
      font-weight: 500;
    }

    .logout-btn {
      background: #c0392b;
      color: white;
      border: none;
      padding: 8px 16px;
      border-radius: 20px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      text-decoration: none;
      display: inline-block;
    }

    .logout-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 15px rgba(192, 57, 43, 0.4);
    }

    /* Main Content */
    .main-content {
      display: flex;
      height: calc(100vh - 70px);
    }

    /* Map Container */
    .map-container {
      position: relative;
      flex: 2;
      background: #050510;
    }

    #map {
      width: 100%;
      height: 100%;
    }

    /* Sidebar */
    .sidebar {
      flex: 1;
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(20px);
      border-left: 1px solid rgba(255, 255, 255, 0.1);
      padding: 20px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    /* Form Container */
    .form-container h2 {
      font-family: 'Orbitron', monospace;
      font-size: 24px;
      font-weight: 700;
      color: white;
      margin-bottom: 20px;
      text-shadow: 0 0 10px rgba(192, 57, 43, 0.3);
    }

    .form-container h2::before {
      content: '';
      display: inline-block;
      width: 4px;
      height: 24px;
      background: #c0392b;
      margin-right: 10px;
      vertical-align: middle;
    }

    .form-group {
      margin-bottom: 15px;
    }

    .form-group label {
      display: block;
      color: #aaa;
      font-size: 14px;
      margin-bottom: 5px;
      font-weight: 500;
    }

    .form-group input,
    .form-group select {
      width: 100%;
      padding: 12px;
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 8px;
      color: white;
      font-size: 14px;
      transition: all 0.3s ease;
    }

    .form-group input:focus,
    .form-group select:focus {
      outline: none;
      border-color: #c0392b;
      box-shadow: 0 0 10px rgba(192, 57, 43, 0.3);
    }

    .form-group input::placeholder {
      color: rgba(255, 255, 255, 0.5);
    }

    .form-group select {
      cursor: pointer;
    }

    .btn-group {
      display: flex;
      gap: 10px;
      margin-top: 20px;
    }

    .btn {
      flex: 1;
      padding: 12px;
      border: none;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    .locate-btn {
      background: #1a2a6c;
      color: white;
    }

    .locate-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 15px rgba(26, 42, 108, 0.4);
    }

    .submit-btn {
      background: #c0392b;
      color: white;
    }

    .submit-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 15px rgba(192, 57, 43, 0.4);
    }

    .btn::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
      transition: left 0.5s;
    }

    .btn:hover::before {
      left: 100%;
    }

    /* Incidents Container */
    .incidents-container h3 {
      font-family: 'Orbitron', monospace;
      font-size: 20px;
      font-weight: 700;
      color: white;
      margin-bottom: 15px;
      text-shadow: 0 0 10px rgba(192, 57, 43, 0.3);
    }

    .incident-list {
      list-style: none;
      padding: 0;
    }

    .incident-item {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-left: 4px solid #c0392b;
      border-radius: 8px;
      padding: 15px;
      margin-bottom: 10px;
      color: white;
      transition: all 0.3s ease;
    }

    .incident-item:hover {
      transform: translateX(5px);
      box-shadow: 0 4px 15px rgba(192, 57, 43, 0.2);
    }

    .incident-type {
      font-weight: 600;
      color: #c0392b;
      margin-bottom: 5px;
      text-transform: capitalize;
    }

    .incident-coords,
    .incident-time {
      font-size: 12px;
      color: #aaa;
      margin-bottom: 3px;
    }

    /* Footer */
    footer {
      background: #050510;
      color: #666;
      text-align: center;
      padding: 15px;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      font-size: 12px;
    }

    /* Mobile Styles */
    @media (max-width: 768px) {
      .main-content {
        flex-direction: column;
      }

      .map-container {
        flex: none;
        height: 50vh;
      }

      .sidebar {
        flex: none;
        border-left: none;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        max-height: 50vh;
        position: fixed;
        bottom: -100%;
        left: 0;
        right: 0;
        z-index: 999;
        border-radius: 12px 12px 0 0;
        transition: bottom 0.35s cubic-bezier(0.4, 0, 0.2, 1);
      }

      .sidebar.active {
        bottom: 0;
      }

      .toggle-sidebar-btn {
        display: flex !important;
        position: absolute;
        top: 10px;
        right: 10px;
        z-index: 1000;
        background: #1a2a6c;
        color: white;
        border: none;
        padding: 8px 12px;
        border-radius: 20px;
        cursor: pointer;
        font-size: 12px;
        font-weight: 600;
        align-items: center;
        gap: 5px;
      }

      .header {
        padding: 10px 15px;
      }

      .logo {
        font-size: 20px;
      }
    }

    /* Leaflet overrides for dark theme */
    .leaflet-control-container .leaflet-routing-container-hide {
      display: none;
    }

    .leaflet-popup-content-wrapper {
      background: rgba(5, 5, 16, 0.9);
      backdrop-filter: blur(10px);
      color: white;
      border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .leaflet-popup-tip {
      background: rgba(5, 5, 16, 0.9);
    }

    .leaflet-control-attribution {
      background: rgba(5, 5, 16, 0.8);
      color: #aaa;
    }

    .leaflet-control-attribution a {
      color: #c0392b;
    }
  </style>
</head>
<body>
  <%- include('partials/loader') %>

  <!-- HEADER -->
  <header class="header">
    <div class="logo">🗺️ GeoAlert</div>
    <div class="user-info">
      <span class="user-name">Bienvenue</span>
      <a href="/auth/logout" class="logout-btn">Déconnexion</a>
    </div>
  </header>
  
  <!-- CONTENU PRINCIPAL -->
  <div class="main-content">
    <!-- CONTENEUR CARTE -->
    <div class="map-container">
      <div id="map" role="application" aria-label="Carte interactive des incidents"></div>
      
      <!-- BOUTON TOGGLE POUR MOBILE -->
      <button class="toggle-sidebar-btn" id="toggle-sidebar-btn" aria-label="Afficher/masquer le formulaire d'ajout d'incident">
        <span>⬆️ Formulaire</span>
      </button>
    </div>
    
    <!-- SIDEBAR : FORMULAIRE & INCIDENTS -->
    <aside class="sidebar" id="sidebar">
      <!-- FORMULAIRE D'AJOUT D'INCIDENT -->
      <div class="form-container">
        <h2>Ajouter un incident</h2>
        <form id="incident-form" novalidate>
          <div class="form-group">
            <label for="type">Type d'incident</label>
            <select name="type" id="type" required aria-required="true">
              <option value="">-- Choisir le type --</option>
              <option value="accident">Accident</option>
              <option value="bouchon">Bouchon</option>
              <option value="radar">Radar</option>
              <option value="travaux">Travaux</option>
              <option value="danger">Danger routier</option>
            </select>
          </div>
          
          <div class="form-group">
            <label for="lat">Latitude</label>
            <input 
              type="number" 
              id="lat" 
              name="lat" 
              placeholder="Latitude" 
              step="any" 
              readonly 
              required 
              aria-required="true"
              inputmode="decimal"
            />
          </div>
          
          <div class="form-group">
            <label for="lng">Longitude</label>
            <input 
              type="number" 
              id="lng" 
              name="lng" 
              placeholder="Longitude" 
              step="any" 
              readonly 
              required 
              aria-required="true"
              inputmode="decimal"
            />
          </div>
          
          <div class="btn-group">
            <button 
              type="button" 
              class="btn locate-btn" 
              id="locate-btn"
              aria-label="Utiliser votre position GPS actuelle"
            >
              📍 Localisation
            </button>
            <button 
              type="submit" 
              class="btn submit-btn"
              aria-label="Ajouter cet incident à la carte"
            >
              ✓ Ajouter
            </button>
          </div>
        </form>
      </div>
      
      <!-- LISTE DES INCIDENTS RÉCENTS -->
      <div class="incidents-container">
        <h3>📋 Incidents récents</h3>
        <ul class="incident-list" id="incident-list" role="list">
          <!-- Boucle EJS pour afficher les incidents initiaux -->
          <% incidents.forEach(incident => { %>
            <li class="incident-item" role="listitem">
              <div class="incident-type"><%= incident.type %></div>
              <div class="incident-coords">
                <strong>Position :</strong> <%= incident.lat.toFixed(5) %>, <%= incident.lng.toFixed(5) %>
              </div>
              <div class="incident-time">
                <strong>Date :</strong> <%= new Date(incident.createdAt).toLocaleString('fr-FR') %>
              </div>
            </li>
          <% }); %>
        </ul>
      </div>
    </aside>
  </div>
  
  <%- include('partials/footer') %>

  <script src="/loader.js"></script>

  <!-- ============================================
       SCRIPTS EXTERNES
       ============================================ -->
  
  <!-- Bibliothèque Leaflet pour les cartes -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  
  <!-- Bibliothèque Socket.IO pour la communication en temps réel -->
  <script src="/socket.io/socket.io.js"></script>

  <!-- ============================================
       SCRIPT PRINCIPAL DE L'APPLICATION
       ============================================ -->
  <script>
    // ============================================
    // 1. INITIALISATION MOBILE - TOGGLE SIDEBAR
    // ============================================
    
    (function initMobileToggle() {
      const toggleBtn = document.getElementById('toggle-sidebar-btn');
      const sidebar = document.getElementById('sidebar');
      const mainContent = document.querySelector('.main-content');
      
      if (!toggleBtn || !sidebar) return;
      
      // Fermer le sidebar en cliquant sur la carte
      const mapContainer = document.querySelector('.map-container');
      
      function closeSidebar() {
        sidebar.classList.remove('active');
        toggleBtn.textContent = '⬆️ Formulaire';
      }
      
      function toggleSidebar() {
        sidebar.classList.toggle('active');
        toggleBtn.textContent = sidebar.classList.contains('active') ? '⬇️ Masquer' : '⬆️ Formulaire';
      }
      
      // Événements
      toggleBtn.addEventListener('click', toggleSidebar);
      toggleBtn.addEventListener('touchend', (e) => {
        e.preventDefault();
        toggleSidebar();
      });
      
      // Fermer le sidebar au clic sur la carte (désactiver sur desktop)
      if (mapContainer && window.innerWidth < 768) {
        mapContainer.addEventListener('click', closeSidebar);
      }
      
      // Gérer le redimensionnement de la fenêtre
      window.addEventListener('resize', () => {
        if (window.innerWidth >= 768) {
          sidebar.classList.remove('active');
          if (mapContainer) {
            mapContainer.removeEventListener('click', closeSidebar);
          }
        }
      });
    })();

    // ============================================
    // 2. INITIALISATION DE LA CARTE LEAFLET
    // ============================================
    
    // Initialiser la carte centrée sur le Maroc (coordonnées de Rabat)
    const map = L.map('map').setView([34.0209, -6.8416], 7);
    
    // Ajouter la couche de tuiles OpenStreetMap
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributeurs',
      maxZoom: 19
    }).addTo(map);

    // ============================================
    // 3. VARIABLES ET CONFIGURATION
    // ============================================
    
    let marker;                    // Marqueur de position sélectionnée
    let userPositionMarker;        // Marqueur de position utilisateur
    const socket = io();           // Initialisation Socket.IO
    const incidentMarkers = new Map(); // Map pour stocker les marqueurs d'incidents

    // ============================================
    // 4. FONCTION : CHARGER LES INCIDENTS
    // ============================================
    
    async function loadIncidents() {
      try {
        const response = await fetch('/auth/api/incidents');
        const incidents = await response.json();
        
        incidents.forEach(incident => {
          // Créer un cercle rouge pour représenter l'incident
          const circle = L.circle([incident.lat, incident.lng], {
            radius: 100,
            color: '#b21f1f',
            fillColor: '#f03',
            fillOpacity: 0.7,
            weight: 2
          }).addTo(map)
            .bindPopup(`
              <div style="font-weight: bold; color: #1a2a6c;">${incident.type}</div>
              <div style="font-size: 0.9em; color: #666;">
                ${new Date(incident.createdAt).toLocaleString('fr-FR')}
              </div>
            `);
          
          incidentMarkers.set(incident._id, circle);
        });
      } catch (error) {
        console.error('Erreur lors du chargement des incidents:', error);
      }
    }

    // ============================================
    // 5. ÉVÉNEMENT : CLIC SUR BOUTON LOCALISATION
    // ============================================
    
    document.getElementById('locate-btn').addEventListener('click', function() {
      if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(
          function(position) {
            const lat = position.coords.latitude;
            const lng = position.coords.longitude;
            
            // Mise à jour des champs du formulaire
            document.getElementById('lat').value = lat.toFixed(5);
            document.getElementById('lng').value = lng.toFixed(5);
            
            // Centrage de la carte sur la position
            map.setView([lat, lng], 15);
            
            // Mettre à jour le marqueur de position utilisateur
            if (userPositionMarker) map.removeLayer(userPositionMarker);
            
            userPositionMarker = L.marker([lat, lng], {
              icon: L.divIcon({
                className: 'user-position-marker',
                html: '<div class="pulse"></div>',
                iconSize: [20, 20]
              })
            }).addTo(map)
              .bindPopup('📍 Votre position actuelle')
              .openPopup();
          },
          function(error) {
            console.error('Erreur de géolocalisation:', error.message);
            alert('Erreur de géolocalisation : ' + error.message);
          },
          {
            enableHighAccuracy: true,
            timeout: 5000,
            maximumAge: 0
          }
        );
      } else {
        alert('La géolocalisation n\'est pas supportée par votre navigateur.');
      }
    });

    // ============================================
    // 6. ÉVÉNEMENT : CLIC SUR LA CARTE
    // ============================================
    
    map.on('click', function(e) {
      const { lat, lng } = e.latlng;
      
      // Mise à jour des champs du formulaire
      document.getElementById('lat').value = lat.toFixed(5);
      document.getElementById('lng').value = lng.toFixed(5);
      
      // Supprimer l'ancien marqueur s'il existe
      if (marker) map.removeLayer(marker);
      
      // Créer un nouveau marqueur à la position cliquée
      marker = L.marker([lat, lng]).addTo(map)
        .bindPopup('📌 Position sélectionnée')
        .openPopup();
      
      // Sur mobile, ouvrir le formulaire
      if (window.innerWidth < 768) {
        const sidebar = document.getElementById('sidebar');
        if (sidebar) {
          sidebar.classList.add('active');
          const toggleBtn = document.getElementById('toggle-sidebar-btn');
          if (toggleBtn) toggleBtn.textContent = '⬇️ Masquer';
        }
      }
    });

    // ============================================
    // 7. ÉVÉNEMENT : ENVOI DU FORMULAIRE
    // ============================================
    
    document.getElementById('incident-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      
      // Récupération des valeurs du formulaire
      const type = document.getElementById('type').value;
      const lat = document.getElementById('lat').value;
      const lng = document.getElementById('lng').value;
      
      // Validation
      if (!type || !lat || !lng) {
        alert('Veuillez remplir tous les champs');
        return;
      }
      
      try {
        // Envoi des données au serveur
        const response = await fetch('/auth/add-incident', {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ type, lat, lng })
        });
        
        if (response.ok) {
          // Réinitialiser le formulaire
          document.getElementById('type').value = '';
          document.getElementById('lat').value = '';
          document.getElementById('lng').value = '';
          
          alert('Incident ajouté avec succès!');
          
          // Fermer le sidebar sur mobile
          const sidebar = document.getElementById('sidebar');
          if (sidebar && window.innerWidth < 768) {
            sidebar.classList.remove('active');
            const toggleBtn = document.getElementById('toggle-sidebar-btn');
            if (toggleBtn) toggleBtn.textContent = '⬆️ Formulaire';
          }
        } else {
          const error = await response.text();
          alert('Erreur: ' + error);
        }
      } catch (err) {
        console.error('Erreur:', err);
        alert('Une erreur est survenue lors de l\'ajout de l\'incident');
      }
    });

    // ============================================
    // 8. SOCKET.IO : RECEVOIR LES NOUVEAUX INCIDENTS
    // ============================================
    
    socket.on('newIncident', (incident) => {
      // Ajouter un cercle rouge pour le nouvel incident
      const circle = L.circle([incident.lat, incident.lng], {
        radius: 100,
        color: '#b21f1f',
        fillColor: '#f03',
        fillOpacity: 0.7,
        weight: 2
      }).addTo(map)
        .bindPopup(`
          <div style="font-weight: bold; color: #1a2a6c;">${incident.type}</div>
          <div style="font-size: 0.9em; color: #666;">
            ${new Date(incident.createdAt).toLocaleString('fr-FR')}
          </div>
        `);
      
      incidentMarkers.set(incident._id, circle);
      
      // Ajouter à la liste des incidents
      const incidentList = document.getElementById('incident-list');
      const newItem = document.createElement('li');
      newItem.className = 'incident-item';
      newItem.setAttribute('role', 'listitem');
      newItem.innerHTML = `
        <div class="incident-type">${incident.type}</div>
        <div class="incident-coords">
          <strong>Position :</strong> ${incident.lat.toFixed(5)}, ${incident.lng.toFixed(5)}
        </div>
        <div class="incident-time">
          <strong>Date :</strong> ${new Date(incident.createdAt).toLocaleString('fr-FR')}
        </div>
      `;
      
      if (incidentList) {
        incidentList.insertBefore(newItem, incidentList.firstChild);
      }
    });

    // ============================================
    // 9. DÉMARRAGE
    // ============================================
    
    // Charger les incidents au démarrage
    loadIncidents();
    
    // Log de démarrage
    console.log('✅ GeoAlert initialisé avec succès');
  </script>
</body>
</html>